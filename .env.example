# --- Required -------------------------------------------------
OANDA_ENV=practice                # practice | live
OANDA_API_TOKEN=your-token-here   # OANDA -> Manage API Access
OANDA_ACCOUNT_ID=101-001-1234567-001

# --- Optional overrides (defaults shown) ------------------------
