# ENABLED_SESSIONS=LONDON,NEWYORK
# DISABLED_WEEKDAYS=
# DISABLED_UTC_HOURS=
# RISK_PER_TRADE_PCT=0.5
# MAX_OPEN_TRADES=2
# MAX_DAILY_LOSS_PCT=3.0
# MAX_UNITS=100000
# SL_ATR_MULT=1.5
# TP_R_MULT=2.0
# LONDON_OPEN_UTC=7
# NY_OPEN_UTC=12
# POLL_SECONDS=60
# TRADING_ENABLED=true
# DATA_DIR=./data                 # point at a Railway volume mount to persist
