# --- Required -------------------------------------------------
OANDA_ENV=practice                # practice | live
OANDA_API_TOKEN=your-token-here   # OANDA -> Manage API Access
OANDA_ACCOUNT_ID=101-001-1234567-001

# --- Dashboard auth (strongly recommended on a public URL) ------
# DASHBOARD_PASSWORD=pick-a-long-random-password   # empty = auth disabled
# DASHBOARD_USER=trader

# --- Optional overrides (defaults shown) ------------------------
# INSTRUMENTS=EUR_USD,GBP_USD,USD_JPY,AUD_USD,USD_CAD
# ENABLED_SESSIONS=LONDON,NEWYORK   # options: LONDON, NEWYORK, LONNY (LON/NY overlap 13-16 UTC)
# OVERLAP_OPEN_UTC=13
# OVERLAP_RANGE_H=4
# OVERLAP_ENTRY_H=3
# DISABLED_WEEKDAYS=
# DISABLED_UTC_HOURS=
# NEWS_FILTER_ENABLED=false
# NEWS_PROVIDER=finnhub
# NEWS_API_KEY=
# NEWS_BLOCK_BEFORE_MIN=60
# NEWS_BLOCK_AFTER_MIN=30
# NEWS_MIN_IMPACTS=high
# NEWS_FAIL_CLOSED=true
# RISK_PER_TRADE_PCT=0.5
# MAX_OPEN_TRADES=2
# MAX_DAILY_LOSS_PCT=3.0
# MAX_UNITS=100000
# SL_ATR_MULT=1.5
# TP_R_MULT=2.0
# LONDON_OPEN_UTC=7
# NY_OPEN_UTC=12
# POLL_SECONDS=60
# TRADING_ENABLED=true
# DATA_DIR=./data                 # point at a Railway volume mount to persist
